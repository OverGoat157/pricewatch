# Скопируйте в .env и заполните перед `docker compose up`.

# Порт, на котором приложение будет доступно в браузере (http://localhost:<APP_PORT>).
APP_PORT=8080

# Секрет для подписи JWT (любая длинная случайная строка).
JWT_SECRET=replace-with-a-long-random-string

# Токен Telegram-бота из @BotFather (без него уведомления в Telegram отключены).
TELEGRAM_BOT_TOKEN=
# Username бота без @ (например, my_pricewatch_bot) — для кнопки «Подключить Telegram».
TELEGRAM_BOT_NAME=

# Как часто планировщик опрашивает цены (минуты). Для демо можно поставить 1.
CHECK_INTERVAL_MINUTES=30
