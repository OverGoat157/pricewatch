# Скопируйте в .env и заполните перед `docker compose up`.

# Порт, на котором приложение будет доступно в браузере (http://localhost:<APP_PORT>).
APP_PORT=8080

# Секрет для подписи JWT (любая длинная случайная строка).
JWT_SECRET=replace-with-a-long-random-string

# Токен Telegram-бота из @BotFather (без него уведомления в Telegram отключены).
TELEGRAM_BOT_TOKEN=
# Username бота без @ (например, my_pricewatch_bot) — для кнопки «Подключить Telegram».
TELEGRAM_BOT_NAME=
# Прокси для api.telegram.org, если он заблокирован у провайдера (РФ).
# Поддерживаются http://, https://, socks5://[user:pass@]host:port. Пример:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
TELEGRAM_PROXY=

# Как часто планировщик опрашивает цены (минуты). Для демо можно поставить 1.
CHECK_INTERVAL_MINUTES=30

# Точный адрес карточного API Wildberries (если известен рабочий).
# По умолчанию парсер сам перебирает несколько адресов. Пример:
# WB_DETAIL_URL=https://card.wb.ru/cards/v2/detail
WB_DETAIL_URL=
